              { url: 'no-torture.html', num: 5, title: 'Ninguna tortura' },
              { url: 'you-have-rights-everywhere.html', num: 6, title: 'Tienes Derechos Donde Quiera' },
            ].map((video, index) => (
              <a 
                key={index}
                href={`https://www.unidosporlosderechoshumanos.mx/what-are-human-rights/videos/${video.url}`}
                target="_blank"
                rel="noopener noreferrer"
                className="group bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300"
              >
                <div className="aspect-video bg-gradient-to-br from-blue-800 to-blue-900 flex items-center justify-center relative overflow-hidden">
                  <div className="absolute inset-0 flex items-center justify-center">
                    <div className="w-16 h-16 bg-yellow-500/90 rounded-full flex items-center justify-center group-hover:bg-yellow-400 transition-colors">
                      <Video className="w-8 h-8 text-white ml-1" />
